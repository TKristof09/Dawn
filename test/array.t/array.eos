const print = fun(s: str)  = @extern("print");
const print_int = fun(i: i64)  = @extern("print_int");

const print_val = fun(i : i64, v : i64) {
    print_int(i);
    print("   :   ");
    print_int(v);
    print("\n");
};

let arr: i64[20];
let arr_size: i64 = 20;

let i: int = 0;
while(i < arr_size){
    print_val(i, arr[i]);
    arr[i] = i;
    i = i + 1;
}
print("\n");
i = 0;
while(i < arr_size){
    print_val(i, arr[i]);
    arr[i] = -i;
    i = i + 1;
}
print("\n");
i = 0;
while(i < arr_size){
    print_val(i, arr[i]);
    i = i + 1;
}
