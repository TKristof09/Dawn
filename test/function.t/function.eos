const f = fun(print_fn: (i64 -> void), a: i32, b: i32, c: i32, d: i32, e: i32) -> i32 {
    let res: i32 = a + b + c + d + e;
    print_fn(res);
    res
};

let print_fun : i32 -> void = print_int;
f(print_fun, 1,2,3,4,5);

print_fun = print2;
f(print_fun, 1,2,3,4,5);

const print_int = fun(i: i64) = @extern("print_int");
const print = fun(s: str) = @extern("print");
const print2 = fun(i: i64) {
    print("\nOther fn: ");
    print_int(10 + i)
};
