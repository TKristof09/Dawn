const f = fun(print_fn: (i64 -> void), a: i64, b: i64, c: i64, d: i64, e: i64) -> i64 {
    let res: i64 = a + b + c + d + e;
    print_fn(res);
    res
};

let print_fun : i64 -> void = print_int;
f(print_fun, 1,2,3,4,5);

print_fun = print2;
f(print_fun, 1,2,3,4,5);

const print_int = fun(i: i64) = @extern("print_int");
const print = fun(s: str) = @extern("print");
const print2 = fun(i: i64) {
    print("\nOther fn: ");
    print_int(10 + i)
};
