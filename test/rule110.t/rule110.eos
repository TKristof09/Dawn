const print = fun(c:str) = @extern("print");


let board_size: i32 = 30;
let board: i32[30]; // 2*30

let k: i32 = 0;

while(k < board_size)
{
    if(k == 0)
    {
        board[k] = 1;
        board[k + board_size] = 1;
    }
    else{
        if(k == board_size - 1)
        {
            board[k] = 1;
            board[k + board_size] = 1;
        }
        else {
            board[k] = 0;
            board[k + board_size] = 0;
        }
    }

    k = k + 1;
}

let i: i32 = 0;
let j: i32 = 1;
let curr_board: i32 = 0;

let a:i32;
let b:i32;
let c:i32;

let patterns: i32[8];
patterns[0] = 0;
patterns[1] = 1;
patterns[2] = 1;
patterns[3] = 1;
patterns[4] = 0;
patterns[5] = 1;
patterns[6] = 1;
patterns[7] = 0;

let lookup: i32;
let next_board: i32 = 0;
while(i < board_size)
{
    j = 0;
    while(j < board_size)
    {
        if(board[curr_board * board_size + j] == 0) {
            print(" ");
        }
        else {
            print("#");
        }

        j = j + 1;
    }
    print("\n");
    j = 1;
    next_board = 1 - curr_board;
    while(j < (board_size - 1))
    {
        let idx: i32 = curr_board * board_size + j;
        a = board[idx - 1];
        b = board[idx];
        c = board[idx + 1];
        lookup = (a << 2) | (b << 1) | c;
        lookup = lookup & 7;

        idx = next_board * board_size + j;
        board[idx] = patterns[lookup];

        j = j + 1;
    }
    curr_board = next_board;
    i = i + 1;
}


