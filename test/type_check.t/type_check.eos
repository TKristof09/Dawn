fun print(c:str) = @extern("print");
fun testFn(x: i64, y: i64) -> bool
{
    if(x == 0)
    {
        print(2000);
    }
    else
    {
        print(x);
        print(y);
        x = x - 1;
        testFn(x, y);
    }
}

let y:bool = 5; // TODO: this shouldn't be allowed but we don't detect types at variable declaration yet
let x:i64 = 69;
testFn(y, x, y);
