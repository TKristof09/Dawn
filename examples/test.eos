const print = fun(s: str) -> void = @extern("print");
const print_int = fun(i: i64) -> void = @extern("print_int");
const S = type { 
    a: u32,
    b: u32
};

const TT = trait {
    g: (Self, u32) -> u32
};

impl TT for S {
    g = fun(self: Self, x: u32) -> u32 {
        self.f(self, 5,6) + x
    }
}

const T = trait {
    f: (Self, u32, u32) -> u32 
};

impl T for S {
    f = fun (self: Self, x: u32, y: u32) -> u32 {
        self.a + x + y
    }
}


const s = S{.a = 34, .b = 35};
print_int(S.g(s, 1));

print("\n");
