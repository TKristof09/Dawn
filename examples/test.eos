const print = fun(s: str) -> void = @extern("print");

const s = "hello";

const S = type {
    left: str,
    right: str
};
const f = fun(s: str) -> S {
    S{
        .left = s,
        .right = " world"
    }
};
const x = f(s);
print(x.left);
print(x.right);
