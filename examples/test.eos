const print = fun(s: str) -> void = @extern("print");
const print_int = fun(i: i64) -> void = @extern("print_int");
const S = type { 
    a: u32,
    b: u32
};
const T = trait {
    f: (u32, u32) -> u32 
};

impl T for S {
    f = fun (x: u32, y: u32) -> u32 {
        x + y
    }
}

const s = S{.a = 34, .b = 35};
print_int(S.f(s.a, s.b));

print("\n");

const SS = type {
    a: u32
};

impl T for SS {
    f = fun (x: u32, y: u32) -> u32 {
        x * y
    }
}

const ss = SS{.a = 6};
print_int(SS.f(ss.a, ss.a));
